# ── App ────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
API_BASE_URL=https://api.yourdomain.com

# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGINS=https://admin.yourdomain.com,https://vendor.yourdomain.com,https://yourdomain.com

# ── Database ───────────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME

# ── JWT ────────────────────────────────────────────────────────────────────────
# Use a long random string — openssl rand -hex 32
JWT_ACCESS_SECRET=replace_with_a_strong_random_secret_minimum_32_chars
JWT_REFRESH_SECRET=replace_with_a_different_strong_random_secret_32_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ── Cookies ────────────────────────────────────────────────────────────────────
# Set to your root domain so cookies work across subdomains
COOKIE_DOMAIN=yourdomain.com
COOKIE_SECURE=true

# ── File Uploads ───────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=10

# ── Cloudflare R2 (object storage) ────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your-bucket-name
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxx.r2.dev

# ── Google OAuth (optional) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Razorpay (optional) ────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── SMTP / Mail (optional) ─────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
